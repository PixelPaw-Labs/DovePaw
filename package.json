    "nanoid": "^5.1.11",
    "next": "^16.2.9",
    "react": "^19.2.6",
    "react-dom": "^19.2.7",
    "react-icons": "^5.6.0",
    "react-jsx-parser": "^2.4.1",
    "shiki": "^4.2.0",
    "streamdown": "^2.5.0",
    "tailwind-merge": "^3.6.0",
    "tokenlens": "^1.3.1",
    "tw-animate-css": "^1.4.0",
